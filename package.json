{
  "name": "skakatur-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "oxlint --fix . && oxfmt .",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "lefthook",
      "sharp",
      "workerd"
    ]
  }
}
