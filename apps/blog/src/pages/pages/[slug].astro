---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const stats = [
	{ k: "Founded", v: "2026" },
	{ k: "Issue", v: "№ 042" },
	{ k: "Frequency", v: "Weekly" },
	{ k: "Trackers", v: "0" },
];

const tenets = [
	{ n: "I", t: "Slow over fast" },
	{ n: "II", t: "Craft over churn" },
	{ n: "III", t: "Signal over noise" },
	{ n: "IV", t: "Strange over safe" },
];
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<div class="min-h-screen">
		<section class="max-w-[900px] mx-auto px-6 py-12 grid grid-cols-12 gap-6">
			<!-- Particulars sidebar -->
			<aside class="col-span-12 md:col-span-4">
				<div class="border-l-2 pl-4 mono text-[11px] tracking-[0.18em] uppercase" style={`border-color: var(--accent)`}>
					<h1 class="text-[1.25rem] tracking-normal normal-case display font-bold mb-4" {...page.edit.title}>{page.data.title}</h1>

					<a href="/" class="acid-link text-muted-foreground hover:text-foreground transition-colors mb-4 inline-block">← Front</a>

					<dl class="space-y-1.5 mt-2">
						{stats.map((s) => (
							<div class="flex items-baseline gap-2">
								<dt class="text-muted-foreground">{s.k}</dt>
								<span class="flex-1 border-b border-dotted border-foreground/25 translate-y-[-3px]" />
								<dd class="text-foreground">{s.v}</dd>
							</div>
						))}
					</dl>
				</div>
			</aside>

			<!-- Content area -->
			<div class="col-span-12 md:col-span-8 max-w-[60ch]">
				<div class="serif text-[1.1rem] leading-[1.7] [&_p]:mb-4 [&_h2]:text-[1.4rem] [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:font-bold [&_h2]:display [&_h2]:tracking-tight [&_h3]:text-[1.15rem] [&_h3]:mt-6 [&_h3]:mb-2 [&_h3]:font-semibold [&_h3]:display [&_blockquote]:my-6 [&_blockquote]:pl-6 [&_blockquote]:border-l-3 [&_blockquote]:border-border [&_blockquote]:text-muted-foreground [&_blockquote]:italic [&_ul]:mb-4 [&_ul]:pl-5 [&_ol]:mb-4 [&_ol]:pl-5 [&_li]:mb-1 [&_pre]:my-4 [&_pre]:p-4 [&_pre]:bg-card [&_pre]:rounded [&_pre]:mono [&_pre]:text-sm [&_pre]:overflow-x-auto [&_code]:mono [&_code]:text-[0.9em] [&_code]:bg-card [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded [&_pre_code]:bg-transparent [&_pre_code]:p-0">
					<PortableText value={page.data.content} />
				</div>

				<!-- Tenets / Manifesto -->
				<div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 mono text-[10px] tracking-[0.2em] uppercase">
					{tenets.map((t) => (
						<span class="flex items-baseline gap-2">
							<span class="font-semibold" style={`color: var(--accent)`}>{t.n}.</span>
							<span class="text-foreground">{t.t}</span>
						</span>
					))}
				</div>
			</div>
		</section>

		<!-- Page footer -->
		<footer class="border-t border-border">
			<div class="max-w-[900px] mx-auto px-6 py-4 flex justify-between mono text-[10px] tracking-[0.2em] uppercase text-muted-foreground">
				<span>© 2026 SK/Dispatch</span>
				<span>Syne · Spectral · JetBrains Mono</span>
			</div>
		</footer>
	</div>
</Base>
