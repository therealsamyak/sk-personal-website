---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import { getReadingTime, extractText } from "../utils/reading-time";

const query = Astro.url.searchParams.get("q")?.trim() || "";

const { entries: allPosts } = await getEmDashCollection("posts");

// Simple search: match query against title, excerpt, and content
function matchesQuery(post: (typeof allPosts)[0], q: string): boolean {
	if (!q) return false;
	const lower = q.toLowerCase();
	const title = (post.data.title || "").toLowerCase();
	const excerpt = (post.data.excerpt || "").toLowerCase();
	// Extract plain text from portable text blocks (avoids matching on _type, _key, etc.)
	const content = extractText(post.data.content).toLowerCase();
	return (
		title.includes(lower) || excerpt.includes(lower) || content.includes(lower)
	);
}

function formatDate(date: Date | undefined): string {
	if (!date) return "";
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}

const results = query ? allPosts.filter((p) => matchesQuery(p, query)) : [];
---

<Base
	title={query ? `Search: ${query}` : "Search"}
	description="Search dispatches"
>
	<div class="max-w-[1400px] mx-auto px-6 py-10">
		<h1 class="display text-4xl font-extrabold tracking-tight mb-8">Search dispatches</h1>

		<form method="get" action="/search" class="flex gap-2 mb-10">
			<input
				type="search"
				name="q"
				value={query}
				placeholder="Search dispatches..."
				class="mono flex-1 px-3 py-2 text-sm border border-foreground bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent"
				autofocus
			/>
			<button
				type="submit"
				class="mono text-[11px] tracking-[0.15em] uppercase px-6 py-2 bg-accent text-accent-foreground border border-accent cursor-pointer hover:opacity-90 transition-opacity"
			>
				Search
			</button>
		</form>

		{
			query && (
				<p class="mono text-[11px] tracking-[0.2em] uppercase text-muted-foreground mb-6">
					{results.length === 0
						? `No signals found for "${query}"`
						: `${results.length} result${results.length === 1 ? "" : "s"} for "${query}"`}
				</p>
			)
		}

		{
			results.length > 0 && (
				<div class="flex flex-col gap-8">
					{results.map((post) => (
						<a
							href={`/posts/${post.id}`}
							class="ledger-row block p-4 -mx-4 no-underline"
						>
							<h2 class="display text-lg font-bold text-foreground mb-1">
								{post.data.title}
							</h2>
							{post.data.excerpt && (
								<p class="serif text-sm text-muted-foreground leading-relaxed mb-2">
									{post.data.excerpt}
								</p>
							)}
							<span class="mono text-[10px] tracking-[0.2em] uppercase text-muted-foreground">
								{formatDate(post.data.publishedAt ?? undefined)}
								{getReadingTime(post.data.content) && (
									<> · {getReadingTime(post.data.content)}</>
								)}
							</span>
						</a>
					))}
				</div>
			)
		}

		{!query && (
			<p class="mono text-[11px] tracking-[0.2em] uppercase text-muted-foreground">
				Enter a search term to find dispatches
			</p>
		)}
	</div>
</Base>
