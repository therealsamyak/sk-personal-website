---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found">
	<div class="min-h-[60vh] flex items-center justify-center">
		<div class="text-center border border-foreground p-10 bg-card">
			<div class="display text-7xl font-extrabold leading-none text-accent">404</div>
			<p class="mono text-[11px] tracking-[0.25em] uppercase text-muted-foreground my-4">Signal not on file</p>
			<a href="/" class="acid-link mono text-[11px] tracking-[0.22em] uppercase text-accent">← Return to front</a>
		</div>
	</div>
</Base>
