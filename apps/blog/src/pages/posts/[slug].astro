---
import {
	getEmDashEntry,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getReadingTime, extractText } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Note: post.id is the slug, post.data.id is the database ULID
const categories = await getEntryTerms("posts", post.data.id, "category");
const category = categories[0];

// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];
const authorName = bylines.map((c) => c.byline.displayName).join(", ") || "SK";

// Reading time and word count
const readingTime = getReadingTime(post.data.content);
const plainText = extractText(post.data.content);
const wordCount = plainText ? plainText.split(/\s+/).filter(Boolean).length : 0;
const wordsFormatted = wordCount.toLocaleString("en-US");

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="min-h-screen">
		{/* HEAD — dense, no wasted space */}
		<header class="max-w-[1400px] mx-auto px-6 pt-5 pb-4 border-b-2 border-foreground">
			<div class="flex flex-wrap items-baseline justify-between gap-2 mono text-[10px] tracking-[0.22em] uppercase text-muted-foreground mb-3">
				<a href="/" class="acid-link text-foreground">← Front</a>
				<span>
					{category && <span style={{ color: "var(--accent)" }}>§ {category.label}</span>}
					{category && " · "}
					{publishDate}
					{publishDate && " · "}
					{readingTime} min · {wordsFormatted} words
				</span>
				<span>By <span class="text-foreground">{authorName}</span></span>
			</div>

			<h1
				class="display"
				style={{
					fontSize: "clamp(2rem, 4.5vw, 3.75rem)",
					fontWeight: 800,
					lineHeight: 1.0,
					letterSpacing: "-0.045em",
				}}
				{...post.edit.title}
			>
				{post.data.title}
			</h1>
		</header>

		{/* Featured image */}
		{
			post.data.featured_image && (
				<div class="max-w-[1400px] mx-auto px-6 py-6" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} />
				</div>
			)
		}

		{/* BODY — 12-col with marginalia */}
		<div class="max-w-[1400px] mx-auto px-6 py-10 grid grid-cols-12 gap-6">
			{/* Marginalia rail */}
			<aside class="col-span-12 md:col-span-3 md:sticky md:top-32 self-start">
				<div class="border-l-2 pl-4 space-y-4 mono text-[10px] tracking-[0.22em] uppercase" style={{ borderColor: "var(--accent)" }}>
					{
						category && (
							<div>
								<div class="text-muted-foreground">§ Filed</div>
								<div style={{ color: "var(--accent)" }}>{category.label}</div>
							</div>
						)
					}
					{
						publishDate && (
							<div>
								<div class="text-muted-foreground">§ Dateline</div>
								<div class="text-foreground">{publishDate}</div>
							</div>
						)
					}
					<div>
						<div class="text-muted-foreground">§ Length</div>
						<div class="text-foreground">{wordsFormatted} words · {readingTime} min</div>
					</div>
					<div>
						<div class="text-muted-foreground">§ Byline</div>
						<div class="text-foreground">{authorName}</div>
					</div>
					<div class="pt-3 border-t border-border">
						<div class="text-muted-foreground mb-2">§ Section index</div>
						<ol id="toc-content" class="space-y-1 normal-case tracking-normal" style={{ fontSize: "11px" }}>
							{/* Populated by client-side JS */}
						</ol>
					</div>
				</div>
			</aside>

			{/* Body copy */}
			<div class="col-span-12 md:col-span-9">
				{
					post.data.excerpt && (
						<p class="serif text-lg leading-relaxed text-muted-foreground mb-8" {...post.edit.excerpt}>
							{post.data.excerpt}
						</p>
					)
				}

				<div id="article-content" class="article-body max-w-[68ch]">
					<PortableText value={post.data.content} />
				</div>

				{/* End of dispatch marker */}
				<div class="mt-8 flex items-center gap-3 mono text-[10px] tracking-[0.22em] uppercase text-muted-foreground">
					<span class="w-2 h-2 inline-block" style={{ background: "var(--accent)" }} />
					End of dispatch · {wordsFormatted} words
				</div>

				{/* Back to front link */}
				<div class="mt-8 pt-4 border-t-2 border-foreground">
					<a href="/" class="acid-link mono text-[11px] tracking-[0.22em] uppercase" style={{ color: "var(--accent)" }}>← Back to front</a>
				</div>

				{/* Comments */}
				<div class="mt-16 pt-10 border-t border-border">
					<Comments collection="posts" contentId={post.data.id} threaded />
					<CommentForm collection="posts" contentId={post.data.id} />
				</div>
			</div>
		</div>
	</article>

	<script>
		// Build TOC from h2/h3 headings in article body
		function buildToc() {
			const content = document.getElementById("article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) return;

			let index = 0;
			headings.forEach((heading) => {
				// Add ID if missing
				if (!heading.id) {
					heading.id = `section-${index}`;
				}
				index++;

				const li = document.createElement("li");
				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link";
				const isH3 = heading.tagName === "H3";

				const num = document.createElement("span");
				num.className = "toc-num tabular-nums";
				num.textContent = index.toString().padStart(2, "0");

				const text = document.createElement("span");
				text.className = "line-clamp-1";
				if (isH3) text.style.paddingLeft = "0.75rem";
				text.textContent = heading.textContent;

				link.appendChild(num);
				link.appendChild(text);
				li.appendChild(link);
				tocContainer.appendChild(li);
			});

			// Highlight current section on scroll
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link) {
							if (entry.isIntersecting) {
								tocContainer
									.querySelectorAll(".toc-link")
									.forEach((l) => l.classList.remove("active"));
								link.classList.add("active");
							}
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" }
			);

			headings.forEach((heading) => observer.observe(heading));

			// Add dropcap to first paragraph in article body
			const firstP = content.querySelector("p");
			if (firstP) {
				firstP.classList.add("dropcap", "serif");
			}
		}

		buildToc();
	</script>
</Base>
