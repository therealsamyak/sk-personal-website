# EmDash Authentication
# Generate with: npx emdash auth secret
# Set with: wrangler secret put EMDASH_AUTH_SECRET
EMDASH_AUTH_SECRET=your_auth_secret_here

# EmDash Preview
# Generate with: npx emdash auth secret
# Set with: wrangler secret put EMDASH_PREVIEW_SECRET
EMDASH_PREVIEW_SECRET=your_preview_secret_here

# Site URL (optional — set if behind reverse proxy or for custom domain)
# Can also be set via wrangler secret put EMDASH_SITE_URL
EMDASH_SITE_URL=https://blog.skakatur.dev
